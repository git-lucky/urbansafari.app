---
import Poster from '@/layouts/Poster.astro';
---

<Poster>
  <div class="poster-wrap">

    <!-- Accent blob -->
    <div class="blob" aria-hidden="true"></div>

    <!-- Brand mark: mascot + wordmark -->
    <div class="brand rise rise-1">
      <img src="/mascot/atlas-wave.png" alt="" width="64" height="64" class="brand-mascot" aria-hidden="true" />
      <span class="brand-word brand-gold">Urban&nbsp;Safari</span>
    </div>

    <!-- Eyebrow -->
    <p class="eyebrow rise rise-2">Demo Experience</p>

    <!-- Headline -->
    <h1 class="headline rise rise-3">Try Urban Safari</h1>

    <!-- Subhead -->
    <p class="subhead rise rise-4">
      City-wide team building your crew will actually talk about.
    </p>

    <!-- QR code card with peeking mascot -->
    <div class="qr-section rise rise-5">
      <img src="/mascot/atlas-binoculars.png" alt="" class="qr-peek" aria-hidden="true" />
      <div class="qr-card">
        <img
          src="/emailPoster/qr-demo.png"
          alt="QR code — scan to join the Urban Safari demo"
          width="220"
          height="220"
          class="qr-img"
        />
      </div>
    </div>

    <!-- Demo URL -->
    <p class="demo-url">hunt.urbansafari.app/join/demo123</p>

    <!-- Footer note -->
    <p class="poster-footer">No app download required · Works on any device</p>

  </div>
</Poster>

<style>
  /* ── wrapper ── */
  .poster-wrap {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    width: min(100%, 520px);
    padding: 2.5rem 2rem 2rem;
    background: var(--cream);
  }

  /* ── accent blob ── */
  .blob {
    position: absolute;
    top: 50%;
    left: 50%;
    translate: -50% -50%;
    width: 380px;
    height: 380px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--gold-soft) 0%, transparent 70%);
    opacity: 0.45;
    pointer-events: none;
    z-index: 0;
  }

  /* ── all children above blob ── */
  .poster-wrap > * { position: relative; z-index: 1; }

  /* ── brand mark ── */
  .brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .brand-mascot {
    width: 52px;
    height: 52px;
    object-fit: contain;
  }

  .brand-word {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--step-2);
    color: var(--forest);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .brand-gold {
    color: var(--gold);
    font-weight: 800;
  }

  /* ── eyebrow ── */
  .eyebrow {
    margin-block: 0;
    font-size: 1rem;
    color: var(--forest);
  }

  /* ── headline ── */
  .headline {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--step-4);
    color: var(--forest);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-block: 0;
    max-width: 14ch;
  }

  /* ── subhead ── */
  .subhead {
    font-family: var(--font-body);
    font-size: var(--step-0);
    color: var(--forest-soft);
    line-height: 1.45;
    max-width: 36ch;
    margin-block: 0;
  }

  /* ── QR section (peek + card) ── */
  .qr-section {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .qr-peek {
    width: 88px;
    height: 88px;
    object-fit: contain;
    margin-bottom: -22px;
    position: relative;
    z-index: 2;
  }

  /* ── QR card ── */
  .qr-card {
    padding: 1rem;
    background: var(--paper);
    border: var(--stamp-border);
    border-radius: var(--radius-md);
    box-shadow: var(--stamp-shadow);
    display: inline-flex;
    position: relative;
    z-index: 1;
  }

  .qr-img {
    display: block;
    width: 220px;
    height: 220px;
    object-fit: contain;
  }

  /* ── demo URL ── */
  .demo-url {
    font-family: var(--font-mono);
    font-size: var(--step-1);
    font-weight: 700;
    color: var(--forest);
    letter-spacing: 0.02em;
    margin-block: 0;
  }

  /* ── footer note ── */
  .poster-footer {
    font-family: var(--font-body);
    font-size: 0.78rem;
    color: var(--forest-soft);
    margin-block: 0.5rem 0;
    opacity: 0.8;
  }

  /* ─────────────────────────────────────── */
  /*  PRINT — primary output target          */
  /* ─────────────────────────────────────── */
  @media print {
    @page {
      size: letter;
      margin: 0.5in;
    }

    *, *::before, *::after {
      animation: none !important;
      transition: none !important;
    }

    /* Hide grain overlay */
    :global(.grain::before) { display: none !important; }

    body {
      display: block;
      padding: 0;
      background: var(--cream) !important;
    }

    .poster-wrap {
      width: 100%;
      max-width: none;
      padding: 0;
      gap: 0.75rem;
    }

    /* Absolute pt units for reliable cross-browser print sizing */
    .headline    { font-size: 36pt; }
    .subhead     { font-size: 12pt; }
    .demo-url    { font-size: 13pt; }
    .eyebrow     { font-size: 11pt; }
    .poster-footer { font-size: 9pt; }
    .brand-word  { font-size: 16pt; }
    .brand-mascot { width: 40px; height: 40px; }

    /* Preserve stamp card styling */
    .qr-card {
      border: 2.5px solid #0F2419 !important;
      box-shadow: 5px 5px 0 0 #0F2419 !important;
      background: #FFFDF7 !important;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .poster-wrap,
    body {
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
  }
</style>
