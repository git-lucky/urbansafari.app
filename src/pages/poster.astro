---
import Poster from '@/layouts/Poster.astro';
---

<Poster>
  <div class="poster-wrap">

    <!-- Accent blob -->
    <div class="blob" aria-hidden="true"></div>

    <!-- Brand mark: mascot -->
    <div class="brand rise rise-1">
      <img src="/mascot/atlas-binoculars.png" alt="" width="115" height="115" class="brand-mascot" aria-hidden="true" />
    </div>

    <!-- Eyebrow -->
    <p class="eyebrow rise rise-2">Demo Experience</p>

    <!-- Headline -->
    <h1 class="headline rise rise-3">Try Urban Safari</h1>

    <!-- Subhead -->
    <p class="subhead rise rise-4">
      City-wide team building your crew will actually talk about.
    </p>

    <!-- QR code card -->
    <div class="qr-section rise rise-5">
      <a href="https://hunt.urbansafari.app/join/demo123" class="qr-card" target="_blank" rel="noopener">
        <img
          src="/emailPoster/qr-demo.png"
          alt="QR code — scan to join the Urban Safari demo"
          width="220"
          height="220"
          class="qr-img"
        />
      </a>
    </div>

    <!-- Demo URL -->
    <p class="demo-url"><a href="https://hunt.urbansafari.app/join/demo123" class="demo-url-link" target="_blank" rel="noopener">hunt.urbansafari.app/join/demo123</a></p>

    <!-- Footer note -->
    <p class="poster-footer">No app download required · Works on any device</p>

    <!-- Website link -->
    <p class="poster-footer-link">
      Plan your team's next adventure at <a href="https://urbansafari.app" class="footer-url">urbansafari.app</a>
    </p>

  </div>
</Poster>

<style>
  /* ── wrapper ── */
  .poster-wrap {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    width: min(100%, 520px);
    padding: 1.25rem 2rem 2rem;
    background: var(--cream);
  }

  /* ── accent blob ── */
  .blob {
    position: absolute;
    top: 50%;
    left: 50%;
    translate: -50% -50%;
    width: 380px;
    height: 380px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--gold-soft) 0%, transparent 70%);
    opacity: 0.45;
    pointer-events: none;
    z-index: 0;
  }

  /* ── all children above blob ── */
  .poster-wrap > *:not(.blob) { position: relative; z-index: 1; }

  /* ── brand mark ── */
  .brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .brand-mascot {
    width: 115px;
    height: 115px;
    object-fit: contain;
  }

  .brand-word {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: calc(var(--step-2) * 1.5);
    color: #1B6B45;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .brand-gold {
    color: #1B6B45;
    font-weight: 800;
  }

  /* ── eyebrow ── */
  .eyebrow {
    margin-block: 0;
    font-size: 1rem;
    color: #000;
  }

  /* ── headline ── */
  .headline {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--step-4);
    color: #1B6B45;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-block: 0;
    max-width: 14ch;
  }

  /* ── subhead ── */
  .subhead {
    font-family: var(--font-body);
    font-size: var(--step-0);
    color: #333;
    line-height: 1.45;
    max-width: 36ch;
    margin-block: 0;
  }

  /* ── QR section ── */
  .qr-section {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ── QR card ── */
  .qr-card {
    padding: 0.75rem;
    background: var(--paper);
    border: var(--stamp-border);
    border-radius: var(--radius-md);
    box-shadow: var(--stamp-shadow);
    display: inline-flex;
    position: relative;
    z-index: 1;
  }

  .qr-img {
    display: block;
    width: 200px;
    height: 200px;
    object-fit: contain;
  }

  /* ── demo URL ── */
  .demo-url-link {
    color: inherit;
    text-decoration: inherit;
  }

  .demo-url {
    font-family: var(--font-mono);
    font-size: var(--step-1);
    font-weight: 700;
    color: #1B6B45;
    letter-spacing: 0.02em;
    margin-block: 0;
    text-decoration: underline;
    text-decoration-color: var(--gold);
    text-decoration-thickness: 3px;
    text-underline-offset: 4px;
  }

  /* ── footer note ── */
  .poster-footer {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: #333;
    margin-block: 0.5rem 0;
  }

  /* ── footer website link ── */
  .poster-footer-link {
    font-family: var(--font-body);
    font-size: 1.56rem;
    color: #000;
    margin-block: 0;
  }

  .footer-url {
    color: #1B6B45;
    font-weight: 700;
    text-decoration: underline;
    text-decoration-color: var(--gold);
    text-decoration-thickness: 3px;
    text-underline-offset: 4px;
  }

  /* ─────────────────────────────────────── */
  /*  PRINT — primary output target          */
  /* ─────────────────────────────────────── */
  @media print {
    @page {
      size: letter;
      margin: 0.5in;
    }

    *, *::before, *::after {
      animation: none !important;
      transition: none !important;
    }

    /* Hide grain overlay */
    :global(.grain::before) { display: none !important; }

    body {
      display: block;
      padding: 0;
      background: var(--cream) !important;
    }

    .poster-wrap {
      width: 100%;
      max-width: none;
      padding: 0;
      gap: 0.75rem;
    }

    /* Absolute pt units for reliable cross-browser print sizing */
    .headline    { font-size: 36pt; }
    .subhead     { font-size: 12pt; color: #333 !important; }
    .demo-url    { font-size: 13pt; }
    .eyebrow     { font-size: 11pt; }
    .poster-footer { font-size: 10pt; color: #333 !important; }
    .poster-footer-link { font-size: 18pt; }
    .footer-url {
      color: #0F2419 !important;
      text-decoration: none !important;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
    .brand-word  { font-size: 16pt; }
    .brand-mascot { width: 40px; height: 40px; }

    /* Preserve stamp card styling */
    .qr-card {
      border: 2.5px solid #0F2419 !important;
      box-shadow: 5px 5px 0 0 #0F2419 !important;
      background: #FFFDF7 !important;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .poster-wrap,
    body {
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
  }
</style>
