---
import '@/styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Try Urban Safari Free — Demo' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{title}</title>
    <link rel="icon" href="/urban-safari-logo.png" />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=cabinet-grotesk@800,700,500&f[]=satoshi@500,700&f[]=jetbrains-mono@500,700&display=swap"
    />
  </head>
  <body class="grain">
    <slot />

    <style>
      body {
        background: var(--cream);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: var(--gutter);
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
    </style>
  </body>
</html>
