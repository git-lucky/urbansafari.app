---
const steps = [
  {
    n: '01',
    title: 'Tell us the brief',
    body: 'Date, team size, city, vibe. One 15-minute call and we\'ve got it.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 12 19.79 19.79 0 0 1 1.93 3.41 2 2 0 0 1 3.92 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 5.99 5.99l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/><path d="M15.05 5A5 5 0 0 1 19 8.95"/><path d="M15.05 1A9 9 0 0 1 23 8.94"/></svg>`,
  },
  {
    n: '02',
    title: 'We build the expedition',
    body: 'Your custom game (challenges, routes, tech) is ready to go when you are. No logistics on your plate.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  },
  {
    n: '03',
    title: 'Your team plays',
    body: 'Teams race through city challenges, photo missions, trivia, and creative tasks. Live leaderboard, live energy.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/></svg>`,
  },
  {
    n: '04',
    title: 'Everyone leaves grinning',
    body: 'Awards ceremony, highlight reel, and a group photo that means something. Work on Monday feels different.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2z"/></svg>`,
  },
];
---

<section id="how" class="section how">
  <div class="wrap">
    <header class="how-head">
      <p class="eyebrow">The expedition</p>
      <h2>Four steps. Sit back and enjoy the Safari.</h2>
      <p class="lead">
        You show up. We run the day. Your team walks away with a story they'll still
        be telling at next year's kickoff.
      </p>
    </header>

    <ol class="step-grid">
      {steps.map((step) => (
        <li class="step">
          <div class="step-icon"><Fragment set:html={step.icon} /></div>
          <p class="step-num">{step.n}</p>
          <h3>{step.title}</h3>
          <p class="step-body">{step.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .how-head {
    max-width: 48ch;
    margin-bottom: clamp(3rem, 6vw, 4.5rem);
  }
  .how-head .eyebrow { margin-bottom: 0.85rem; display: block; }
  .how-head h2 { margin-bottom: 1rem; }

  .step-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(1.5rem, 3vw, 2.5rem);
    position: relative;
  }
  .step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
  }
  .step-icon {
    width: 96px;
    height: 96px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--gold) 0%, var(--sand) 100%);
    border: 2.5px solid var(--ink);
    border-radius: var(--radius-pill);
    box-shadow: var(--stamp-shadow);
    color: var(--ink);
    margin-bottom: 1.25rem;
    flex-shrink: 0;
  }
  .step-num {
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--moss);
    font-size: 0.9rem;
    letter-spacing: 0.12em;
    margin-bottom: 0.25rem;
  }
  .step h3 {
    font-size: var(--step-2);
    margin-bottom: 0.5rem;
  }
  .step-body {
    color: var(--forest-soft);
    font-size: 0.98rem;
  }

  @media (max-width: 900px) {
    .step-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 520px) {
    .step-grid { grid-template-columns: 1fr; }
  }
</style>
