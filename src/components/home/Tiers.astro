---
import Mascot from '@/components/Mascot.astro';
import { tiers } from '@/content/tiers';
---

<section id="tiers" class="section tiers band-cream-deep">
  <div class="wrap">
    <header class="tiers-head">
      <p class="eyebrow">Four ways to run a Safari</p>
      <h2>Pick the expedition that fits.</h2>
      <p class="lead">
        Same playful spirit across every tier. The difference is how much we
        carry for you, and how custom the day feels for your company.
      </p>
    </header>

    <div class="tier-grid">
      {tiers.map((tier, i) => (
        <article
          class={`tier ${tier.badge ? `tier-${tier.badge}` : ''}`}
          style={`--r:${i % 2 === 0 ? -0.6 : 0.6}deg`}
        >
          {tier.badge && (
            <span class={`tier-badge badge-${tier.badge}`}>{tier.badgeLabel}</span>
          )}
          <div class="tier-mascot">
            <Mascot pose={tier.mascotPose} size="md" />
          </div>
          <h3>{tier.name}</h3>
          <p class="tier-tag">{tier.tagline}</p>
          <p class="tier-desc">{tier.description}</p>
          <ul class="tier-list">
            {tier.includes.map((item) => (
              <li>
                <span class="check" aria-hidden="true">✓</span>
                {item}
              </li>
            ))}
          </ul>
          <a href="#contact" class="btn btn-ghost tier-cta">
            Get a quote
            <span class="arrow" aria-hidden="true">→</span>
          </a>
        </article>
      ))}
    </div>

    <p class="tiers-footnote">
      Not sure which tier fits? Tell us your team size and a rough date.
      We'll recommend one that fits your team and your city.
    </p>
  </div>
</section>

<style>
  .tiers-head {
    max-width: 52ch;
    margin-bottom: clamp(3rem, 6vw, 4.5rem);
  }
  .tiers-head .eyebrow { margin-bottom: 0.85rem; display: block; }
  .tiers-head h2 { margin-bottom: 1rem; }

  .tier-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(1.25rem, 2.5vw, 2rem);
    align-items: stretch;
  }

  .tier {
    position: relative;
    --ink: #1B6B45;
    --stamp-border: 3.5px solid #1B6B45;
    --stamp-shadow: 7px 7px 0 0 #1B6B45;
    background: linear-gradient(to bottom, #FDF1D8 0%, var(--paper) 100%);
    border: var(--stamp-border);
    border-radius: var(--radius-lg);
    padding: 1.75rem 1.5rem;
    box-shadow: var(--stamp-shadow);
    display: flex;
    flex-direction: column;
    transform: rotate(var(--r, 0));
    transition: transform 0.28s cubic-bezier(.2,.9,.3,1.3), box-shadow 0.28s;
  }
  .tier:hover {
    transform: translate(-3px, -6px) rotate(0deg);
    box-shadow: 9px 10px 0 0 var(--ink);
  }

  .tier-popular { border-color: var(--gold); box-shadow: 5px 5px 0 0 var(--gold); }
  .tier-popular:hover { box-shadow: 9px 10px 0 0 var(--gold); }
  .badge-popular { border-color: var(--gold); }

  .tier-premium {
    background:
      linear-gradient(to bottom, #FDF1D8 0%, var(--paper) 100%) padding-box,
      linear-gradient(135deg, var(--gold) 0%, var(--sunset) 50%, var(--gold) 100%) border-box;
    border-color: transparent;
    box-shadow: var(--stamp-shadow-sunset);
    transform: translateY(-6px) rotate(var(--r, 0));
  }

  .tier-premium h3 {
    font-size: calc(var(--step-3) * 2.5 + 4pt);
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: #0F2419;
  }
  .tier-premium::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    opacity: 0.04;
    mix-blend-mode: multiply;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='220' height='220'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
  }
  .tier-premium:hover {
    box-shadow: 9px 10px 0 0 var(--sunset);
    transform: translate(-3px, -12px) rotate(0deg);
  }

  .tier-badge {
    position: absolute;
    top: -14px;
    right: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 0.35rem 0.75rem;
    border: 2px solid var(--ink);
    border-radius: var(--radius-pill);
    background: var(--ink);
    color: var(--paper);
  }
  .badge-popular { background: var(--gold); color: #000; border-color: #000; }
  .badge-premium {
    background: linear-gradient(90deg, var(--sunset), var(--gold));
    color: #000;
    border-color: #000;
  }

  .tier-premium .tier-mascot {
    transform: scale(1.1) translateY(8px);
    transform-origin: center bottom;
  }

  .tier-mascot {
    align-self: center;
    margin-bottom: 1rem;
  }

  .tier h3 {
    font-size: var(--step-3);
    margin-bottom: 0.25rem;
  }
  .tier-tag {
    font-family: var(--font-display);
    font-weight: 600;
    font-style: italic;
    color: var(--moss);
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }
  .tier-desc {
    color: var(--forest-soft);
    font-size: 0.95rem;
    margin-bottom: 1.25rem;
  }

  .tier-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 1.5rem;
    font-size: 0.92rem;
    color: #0F2419;
  }
  .tier-list li {
    display: flex;
    gap: 0.55rem;
    align-items: flex-start;
    line-height: 1.4;
  }
  .check {
    display: inline-grid;
    place-items: center;
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    margin-top: 2px;
    border-radius: 50%;
    background: var(--ink);
    color: var(--cream);
    font-size: 0.7rem;
    font-weight: 700;
  }
  .tier-popular .check { background: var(--coral); }
  .tier-premium .check {
    background: linear-gradient(135deg, var(--sunset), var(--coral));
  }

  .tier-cta {
    margin-top: auto;
    align-self: flex-start;
    padding: 0.7rem 1.2rem;
    font-size: 0.95rem;
  }
  .tier-popular .tier-cta,
  .tier-premium .tier-cta {
    border-color: var(--gold);
    color: var(--gold);
  }
  .tier-popular .tier-cta:hover,
  .tier-premium .tier-cta:hover {
    box-shadow: 3px 3px 0 0 var(--gold);
  }

  .tiers-footnote {
    margin-top: 2.75rem;
    text-align: center;
    color: var(--forest-soft);
    font-style: italic;
    max-width: 48ch;
    margin-inline: auto;
  }

  @media (max-width: 1100px) {
    .tier-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .tier-grid { grid-template-columns: 1fr; }
    .tier { transform: rotate(0) !important; }
  }
</style>
