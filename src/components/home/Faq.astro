---
import { preSaleFaq } from '@/content/faq';
---

<section id="faq" class="section faq">
  <div class="wrap">
    <header class="faq-head">
      <p class="eyebrow">Pre-flight questions</p>
      <h2>Stuff people usually ask on the first call.</h2>
    </header>

    <div class="faq-list">
      {preSaleFaq.map((item, i) => (
        <details class="faq-item" open={i === 0}>
          <summary>
            <span class="faq-q">{item.q}</span>
            <span class="faq-toggle" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.4">
                <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </summary>
          <p class="faq-a">{item.a}</p>
        </details>
      ))}
    </div>

    <p class="faq-footer">
      Want to experience an Urban Safari? <a href="#contact">Drop us a line</a>. We like the tricky questions.
    </p>
  </div>
</section>

<style>
  .faq-head {
    max-width: 48ch;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .faq-head .eyebrow { margin-bottom: 0.85rem; display: block; }

  .faq-list {
    max-width: 760px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .faq-item {
    background: var(--paper);
    border: var(--stamp-border);
    border-radius: var(--radius-md);
    box-shadow: var(--stamp-shadow);
    overflow: hidden;
    transition: box-shadow 0.24s;
  }
  .faq-item[open] { box-shadow: var(--stamp-shadow-coral); }
  .faq-item summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--forest);
    user-select: none;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-toggle {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    background: var(--cream);
    border: 2px solid var(--ink);
    border-radius: 50%;
    color: var(--forest);
    transition: transform 0.24s;
    flex-shrink: 0;
  }
  .faq-item[open] .faq-toggle {
    transform: rotate(-180deg);
    background: var(--gold);
    color: var(--ink);
  }
  .faq-a {
    padding: 0 1.5rem 1.5rem;
    color: var(--forest-soft);
    max-width: none;
    font-size: 1rem;
  }
  .faq-footer {
    margin-top: 2.5rem;
    font-style: italic;
    color: var(--forest);
    font-size: calc(1rem + 3pt);
  }
  .faq-footer a {
    color: var(--forest);
    font-weight: 700;
    border-bottom: 2px solid var(--gold);
  }
</style>
