---
const outcomes = [
  {
    headline: 'Coworkers who laugh together afterward.',
    body: 'Nothing bonds a team faster than laughing together on a city sidewalk, solving something weird and wonderful. People come back from a Safari with inside jokes, not small talk.',
    icon: '😄',
  },
  {
    headline: 'The 200-person offsite that doesn\'t fall apart.',
    body: 'Our platform and crew are built for city-wide hunts where dozens of teams can play at the same time. You get one point of contact; everyone else gets a day that feels effortless.',
    icon: '🧭',
  },
  {
    headline: 'You, looking like the person who gets it.',
    body: 'The best part of booking Urban Safari is that you don\'t have to lift a finger the day-of. Your team thinks you\'re a genius. We\'ll let them keep thinking that.',
    icon: '🏆',
  },
];
---

<section id="outcomes" class="section outcomes">
  <div class="wrap">
    <header class="outcomes-head">
      <p class="eyebrow">What you get</p>
      <h2>Three outcomes we stake our name on.</h2>
    </header>

    <div class="outcome-list">
      {outcomes.map((o) => (
        <article class="outcome">
          <div class="outcome-icon" aria-hidden="true"><Fragment set:html={o.icon} /></div>
          <h3>{o.headline}</h3>
          <p>{o.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .outcomes-head { max-width: 48ch; margin-bottom: clamp(3rem, 6vw, 4.5rem); }
  .outcomes-head .eyebrow { margin-bottom: 0.85rem; display: block; }

  .outcome-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }

  .outcome {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
  }

  .outcome-icon {
    font-size: 3.5rem;
    line-height: 1;
  }

  .outcome h3 {
    font-size: var(--step-2);
    line-height: 1.1;
    margin: 0;
  }
  .outcome p {
    color: var(--forest-soft);
    font-size: 0.95rem;
    margin: 0;
  }

  @media (max-width: 820px) {
    .outcome-list { grid-template-columns: 1fr; }
  }
</style>
