---
const links = [
  { label: 'Experiences',   href: '/#tiers' },
  { label: 'How it works',  href: '/#how' },
  { label: 'Outcomes',      href: '/#outcomes' },
  { label: 'FAQ',           href: '/#faq' },
];
---

<header class="nav">
  <div class="wrap nav-row">
    <a href="/" class="brand" aria-label="Urban Safari, home">
      <span class="brand-mark" aria-hidden="true">
        <img src="/mascot/atlas-wave.png" alt="" width="44" height="44" />
      </span>
      <span class="brand-word brand-gold">Urban&nbsp;Safari</span>
    </a>

    <nav class="nav-links" aria-label="Primary">
      <ul>
        {links.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </nav>

    <a href="/#contact" class="btn btn-coral nav-cta">
      Book a Safari
      <span class="arrow" aria-hidden="true">→</span>
    </a>

    <button type="button" class="hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="mobile-menu" id="mobile-menu" hidden>
    <ul>
      {links.map((l) => (
        <li><a href={l.href}>{l.label}</a></li>
      ))}
      <li><a href="/#contact" class="mobile-cta">Book a Safari →</a></li>
    </ul>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--cream) 92%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 2px solid var(--ink);
    opacity: 1;
    transition: opacity 0.5s ease;
  }
  .nav.nav-hidden {
    opacity: 0;
    pointer-events: none;
  }
  .nav-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 0.9rem;
    gap: 1.5rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.25rem;
    color: var(--forest);
    letter-spacing: -0.02em;
  }
.brand-gold { color: var(--gold); }
  .brand-mark {
    display: inline-block;
    width: 44px;
    height: 44px;
    transition: transform 0.3s;
  }
  .brand-mark img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .brand:hover .brand-mark { transform: rotate(-8deg); }

  .nav-links ul {
    display: flex;
    gap: 2rem;
  }
  .nav-links a {
    font-weight: 500;
    color: var(--forest);
    position: relative;
    padding-block: 0.35rem;
    transition: color 0.18s;
  }
  .nav-links a::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    background: var(--coral);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.24s cubic-bezier(.2,.9,.3,1);
  }
  .nav-links a:hover::after,
  .nav-links a:focus-visible::after {
    transform: scaleX(1);
  }

  .nav-cta { padding: 0.65rem 1.15rem; font-size: 0.95rem; }

  .hamburger {
    display: none;
    width: 40px;
    height: 40px;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    border: 2px solid var(--ink);
    border-radius: 10px;
    background: var(--paper);
  }
  .hamburger span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--ink);
    transition: transform 0.24s, opacity 0.24s;
  }
  .hamburger[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .hamburger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .mobile-menu {
    background: var(--cream);
    border-top: 2px solid var(--ink);
  }
  .mobile-menu ul {
    display: flex;
    flex-direction: column;
    padding: 1rem var(--gutter) 1.5rem;
    gap: 0.2rem;
  }
  .mobile-menu a {
    display: block;
    padding: 0.85rem 0.5rem;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--forest);
    border-bottom: 1px solid color-mix(in srgb, var(--forest-soft) 20%, transparent);
  }
  .mobile-cta {
    color: var(--forest) !important;
    border-bottom: 2px solid var(--gold) !important;
    margin-top: 0.5rem;
  }

  @media (max-width: 900px) {
    .nav-links, .nav-cta { display: none; }
    .hamburger { display: flex; }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.hamburger');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!open));
      toggle.setAttribute('aria-label', open ? 'Open menu' : 'Close menu');
      menu.hidden = open;
    });
    menu.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'Open menu');
        menu.hidden = true;
      });
    });
  }

  const nav = document.querySelector('.nav');
  const contact = document.getElementById('contact');
  if (nav && contact) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          nav.classList.add('nav-hidden');
        } else if (entry.boundingClientRect.top > 0) {
          nav.classList.remove('nav-hidden');
        }
      },
      { threshold: 1.0 }
    );
    observer.observe(contact);
  }
</script>
